# grip-aidata-push 환경 변수 템플릿
# 이 파일을 `.env` 로 복사한 뒤 값을 채우세요. 실제 `.env` 는 절대 커밋하지 않습니다.
#
# 인증 방식: Snowflake key-pair (개인키 .p8 파일, 무암호 PKCS#8)
# 개인키 자체는 repo/이미지에 넣지 말고 호스트에 두고 경로만 지정하세요.

SNOWFLAKE_USER=YOUR_SNOWFLAKE_USER
SNOWFLAKE_ACCOUNT=YOUR_ORG-YOUR_ACCOUNT       # 예: ABCDEFG-HI12345
SNOWFLAKE_WAREHOUSE=XS_BATCH
SNOWFLAKE_DATABASE=PROD_GRIP_DW
SNOWFLAKE_SCHEMA=DEFAULT

# 개인키 경로. 미지정 시 기본값 ~/.snowflake/snowflake.p8 를 사용.
# Docker 로 띄울 때는 호스트의 .p8 를 마운트하고 /app/.snowflake/snowflake.p8 로 지정 (docker-compose.yml 참고).
# SNOWFLAKE_PRIVATE_KEY_PATH=/home/youruser/.snowflake/snowflake.p8
